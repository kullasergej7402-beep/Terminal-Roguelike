{
    "name": "portfolio/terminal-roguelike",
    "description": "Browser-based single-player terminal roguelike written in PHP.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "slim/slim": "^4.10",
        "slim/psr7": "^1.5",
        "vlucas/phpdotenv": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "TerminalRoguelike\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TerminalRoguelike\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "migrate": "php bin/migrate.php"
    },
    "config": {
        "sort-packages": true
    }
}
